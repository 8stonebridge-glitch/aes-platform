# Required for persistent artifact storage and replay
AES_POSTGRES_URL=postgresql://user:password@127.0.0.1:5432/aes

# LLM Configuration (optional — falls back to keyword/template without these)
OPENAI_API_KEY=
AES_LLM_MODEL=gpt-4o

# Optional: Neo4j for knowledge graph (not yet wired)
# AES_NEO4J_URL=bolt://127.0.0.1:7687
# AES_NEO4J_USER=neo4j
# AES_NEO4J_PASSWORD=password

# Deployment (optional — build completes without these)
GITHUB_TOKEN=
AES_GITHUB_ORG=
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# App environment variables (injected into deployed apps)
AES_CLERK_PUBLISHABLE_KEY=
AES_CLERK_SECRET_KEY=
AES_CONVEX_URL=
