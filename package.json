{
  "name": "@aes/platform",
  "version": "0.1.0",
  "type": "module",
  "description": "AES v12 LangGraph.js orchestrator and operator UI",
  "main": "dist/graph.js",
  "bin": {
    "aes": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build --prefix packages/math && tsc",
    "dev": "tsc --watch",
    "aes": "node dist/cli/index.js",
    "start": "node dist/api/index.js",
    "start:api": "node dist/api/index.js",
    "test": "vitest run",
    "verify": "tsc --noEmit",
    "paperclip": "tsx paperclip/aes-agent.ts"
  },
  "dependencies": {
    "@aes/math": "file:./packages/math",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "neo4j-driver": "^5.28.3",
    "ora": "^9.3.0",
    "pg": "^8.20.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "tsx": "^4.21.0",
    "vitest": "^4.1.1"
  }
}
