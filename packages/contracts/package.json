{
  "name": "@aes/contracts",
  "version": "0.1.0",
  "description": "Canonical typed contracts for the AES v12 governed software factory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["aes", "contracts", "zod", "schemas"],
  "license": "MIT",
  "dependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
