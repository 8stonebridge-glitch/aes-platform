{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@aes/math": ["./packages/math/src/index.ts"],
      "@aes/math/*": ["./packages/math/src/*"]
    }
  },
  "include": ["src", "packages/math/src"]
}
