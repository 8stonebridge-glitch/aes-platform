{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@aes/math": ["./packages/math/dist/index.d.ts"],
      "@aes/math/*": ["./packages/math/dist/*"]
    }
  },
  "include": ["src"]
}
