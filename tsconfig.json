{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@aes/math": ["./packages/math/src/index.ts"],
      "@aes/math/*": ["./packages/math/src/*"],
      "@aes/failure-memory": ["./packages/failure-memory/src/index.ts"],
      "@aes/failure-memory/*": ["./packages/failure-memory/src/*"],
      "@aes/graph": ["./packages/graph/src/index.ts"],
      "@aes/graph/*": ["./packages/graph/src/*"]
    }
  },
  "include": ["src", "packages/math/src", "packages/failure-memory/src", "packages/graph/src"]
}
